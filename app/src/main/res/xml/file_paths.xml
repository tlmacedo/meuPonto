<?xml version="1.0" encoding="utf-8"?>
<!--
    Caminhos de arquivos expostos via FileProvider para compartilhamento seguro.

    ATENÇÃO: O atributo `path` deve corresponder EXATAMENTE ao diretório
    usado no código. Divergências causam IllegalArgumentException em tempo
    de execução ao tentar compartilhar arquivos via FileProvider.

    Mapeamento de código → XML:
    - PhotoCaptureManager.TEMP_DIR = "temp_camera"
      → <cache-path name="temp_camera" path="temp_camera/" />
      CORRIGIDO: era "temp/" mas o código usa "temp_camera/"

    - ComprovanteImageStorage.ROOT_DIR = "comprovantes"
      → <files-path name="comprovantes" path="comprovantes/" />
      (correto, sem alteração)

    FileProvider authority: "${applicationId}.fileprovider"
    Declarado em AndroidManifest.xml e usado em PhotoCaptureManager.
-->
<paths>
    <!--
        Diretório de cache para arquivos temporários da câmera.
        Corresponde a: context.cacheDir/temp_camera/
        Usado por: PhotoCaptureManager.prepareForCameraCapture()
        CORRIGIDO em 12.0.0: era path="temp/" — causaria IllegalArgumentException
        pois PhotoCaptureManager usa File(context.cacheDir, "temp_camera")
    -->
    <cache-path
        name="temp_camera"
        path="temp_camera/" />

    <!--
        Diretório de arquivos internos para fotos permanentes de comprovante.
        Corresponde a: context.filesDir/comprovantes/
        Usado por: ComprovanteImageStorage e FotoStorageManager
    -->
    <files-path
        name="comprovantes"
        path="comprovantes/" />

    <!--
        Diretório externo reservado para exportação futura de relatórios.
        Não utilizado atualmente — reservado para Fase 4 (Relatórios).
    -->
    <external-files-path
        name="external_comprovantes"
        path="comprovantes/" />
</paths>